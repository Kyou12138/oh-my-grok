{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" session-start",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" user-prompt",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|WriteFile|StrReplace|SearchReplace|search_replace|search-replace|EditNotebook|NotebookEdit|Delete|DeleteFile|Edit|EditFile|Create|Apply_patch|ApplyPatch|apply_patch|apply-patch|Multiedit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" pre-tool-use",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|read_file|ReadFile",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-read",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "TodoWrite|todo_write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-todo",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|WriteFile|StrReplace|SearchReplace|search_replace|search-replace|Edit|EditFile|Create|Apply_patch|ApplyPatch|apply_patch|apply-patch|Multiedit|MultiEdit|Delete|DeleteFile",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-write",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Bash|Shell|run_terminal_command|run_terminal|Execute|LocalShell",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-shell",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "spawn_subagent|Task|task|call_omo_agent|SpawnSubagent|get_task_output|GetTaskOutput|task_output|get_command_or_subagent_output|wait_tasks|WaitTasks|get_terminal_command_output|GetTerminalCommandOutput",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-spawn",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "enter_plan_mode|EnterPlanMode|exit_plan_mode|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-plan",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" subagent-start",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" subagent-end",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" stop",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" session-end",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
