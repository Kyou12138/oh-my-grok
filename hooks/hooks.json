{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" session-start",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" user-prompt",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|WriteFile|write|write_file|write-file|WriteToFile|write_to_file|write-to-file|StrReplace|SearchReplace|search_replace|search-replace|SearchAndReplace|search_and_replace|FindAndReplace|find_and_replace|StrReplaceEditor|str_replace_editor|ReplaceInFile|replace_in_file|replace-in-file|ReplaceStringInFile|replace_string_in_file|EditNotebook|NotebookEdit|notebook_edit|Delete|DeleteFile|delete|delete_file|delete-file|DeletePath|delete_path|RemoveFile|remove_file|RmFile|rm_file|Edit|EditFile|edit_file|edit-file|FileEdit|file_edit|Create|CreateFile|create|create_file|create-file|CreateOrUpdateFile|create_or_update_file|OverwriteFile|overwrite_file|SaveFile|save_file|UpdateFile|update_file|ModifyFile|modify_file|ChangeFile|change_file|RewriteFile|rewrite_file|PatchFile|patch_file|ApplyDiff|apply_diff|DiffEdit|diff_edit|Patch|patch|Insert|InsertFile|insert_file|Append|AppendFile|append_file|Apply_patch|ApplyPatch|apply_patch|apply-patch|Multiedit|MultiEdit|multi_edit|multi-edit|spawn_subagent|SpawnSubagent|Task|task|call_omo_agent|dispatch_agent|DispatchAgent|run_agent|RunAgent|delegate|Delegate|Bash|bash|Shell|shell|run_terminal_command|run_terminal|Execute|LocalShell|PowerShell|powershell|pwsh|Cmd|cmd|Terminal|terminal|terminal_command|run_command|Exec|exec",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" pre-tool-use",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|read|read_file|ReadFile|read-file|Skill|skill|LoadSkill|load_skill|load-skill|UseSkill|use_skill|use-skill|InvokeSkill|invoke_skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-read",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "TodoWrite|todo_write|todowrite|todo-write|Todo_Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-todo",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|WriteFile|write|write_file|write-file|WriteToFile|write_to_file|write-to-file|StrReplace|SearchReplace|search_replace|search-replace|SearchAndReplace|search_and_replace|FindAndReplace|find_and_replace|StrReplaceEditor|str_replace_editor|ReplaceInFile|replace_in_file|replace-in-file|ReplaceStringInFile|replace_string_in_file|Edit|EditFile|edit_file|edit-file|FileEdit|file_edit|Create|CreateFile|create|create_file|create-file|CreateOrUpdateFile|create_or_update_file|OverwriteFile|overwrite_file|SaveFile|save_file|UpdateFile|update_file|ModifyFile|modify_file|ChangeFile|change_file|RewriteFile|rewrite_file|PatchFile|patch_file|ApplyDiff|apply_diff|DiffEdit|diff_edit|Patch|patch|Insert|InsertFile|insert_file|Append|AppendFile|append_file|Apply_patch|ApplyPatch|apply_patch|apply-patch|Multiedit|MultiEdit|multi_edit|multi-edit|Delete|DeleteFile|delete|delete_file|delete-file|DeletePath|delete_path|RemoveFile|remove_file|RmFile|rm_file|EditNotebook|NotebookEdit|notebook_edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-write",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Bash|bash|Shell|shell|run_terminal_command|run_terminal|Execute|LocalShell|PowerShell|powershell|pwsh|Cmd|cmd|Terminal|terminal|terminal_command|run_command|Exec|exec",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-shell",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "spawn_subagent|Task|task|call_omo_agent|SpawnSubagent|dispatch_agent|DispatchAgent|run_agent|RunAgent|delegate|Delegate|get_task_output|GetTaskOutput|task_output|get_command_or_subagent_output|wait_tasks|WaitTasks|get_terminal_command_output|GetTerminalCommandOutput",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-spawn",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "enter_plan_mode|EnterPlanMode|exit_plan_mode|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-plan",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" subagent-start",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" subagent-end",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" stop",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" session-end",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
