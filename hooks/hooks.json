{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" session-start",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" user-prompt",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|StrReplace|search_replace|EditNotebook|Delete|DeleteFile|Edit|EditFile|Create|Apply_patch|ApplyPatch|Multiedit|WriteFile",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" pre-tool-use",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|read_file",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-read",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "TodoWrite|todo_write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-todo",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|StrReplace|search_replace|Edit|EditFile|Create|Apply_patch|ApplyPatch|Multiedit|WriteFile",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-write",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Bash|Shell|run_terminal_command|run_terminal|Execute|LocalShell",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-shell",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "spawn_subagent|Task|task|call_omo_agent|SpawnSubagent|get_task_output|get_command_or_subagent_output|GetTaskOutput",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" post-tool-spawn",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" stop",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.js\" session-end",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
