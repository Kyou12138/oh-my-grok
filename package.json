{
  "name": "oh-my-grok",
  "version": "1.1.47",
  "description": "omo-style harness for Grok Build — source-aligned hooks: PreTool enforce, SubagentStart/End, Hashline, ULW, Superpowers",
  "type": "module",
  "bin": {
    "omg-hook": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vendor:superpowers": "node scripts/vendor-superpowers.mjs",
    "validate": "node scripts/validate-plugin.mjs",
    "doctor": "node scripts/doctor.mjs",
    "ci": "node scripts/ci.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "homepage": "https://github.com/Kyou12138/oh-my-grok",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kyou12138/oh-my-grok.git"
  },
  "bugs": {
    "url": "https://github.com/Kyou12138/oh-my-grok/issues"
  },
  "keywords": [
    "grok-build",
    "grok-plugin",
    "oh-my-grok",
    "sisyphus",
    "superpowers",
    "agentic-workflow",
    "ultrawork",
    "ralph-loop",
    "skill-gate",
    "harness",
    "xai"
  ],
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
